{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-users-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/users/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "org-dept-route": {
        "ClusterId": "org-cluster",
        "Match": {
          "Path": "/api/departments/{**catch-all}"
        }
      },
      "org-roles-route": {
        "ClusterId": "org-cluster",
        "Match": {
          "Path": "/api/roles/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://localhost:5220"
          }
        }
      },
      "org-cluster": {
        "Destinations": {
          "org-service": {
            "Address": "http://localhost:5221"
          }
        }
      }
    }
  }
}
